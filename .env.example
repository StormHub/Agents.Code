# Authentication (at least one method required)

# Option 1: Direct Anthropic API key
ANTHROPIC_API_KEY=your_api_key_here

# Option 2: OAuth/session token
# ANTHROPIC_AUTH_TOKEN=your_auth_token_here

# Option 3: Custom API base URL (e.g., proxy or gateway)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Option 4: Cloud provider (set to 1 + configure provider credentials)
# CLAUDE_CODE_USE_BEDROCK=1     # Amazon Bedrock (requires AWS credentials)
# CLAUDE_CODE_USE_VERTEX=1      # Google Vertex AI (requires GCP credentials)
# CLAUDE_CODE_USE_FOUNDRY=1     # Microsoft Azure Foundry (requires Azure credentials)

# Option 5: Dynamic key retrieval via shell command
# CLAUDE_API_KEY_HELPER=bash -c 'cat /path/to/secret'

# Optional: Model override (defaults to claude-opus-4-5-20250918)
# MODEL=claude-opus-4-5-20250918

# Optional: Max QA rounds before stopping (default: 3)
# MAX_QA_ROUNDS=3

# Optional: Max budget in USD (default: 50)
# MAX_BUDGET_USD=50
