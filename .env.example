# Authentication (optional — if signed into Claude Code locally, no config needed)

# Direct Anthropic API key
# ANTHROPIC_API_KEY=your_api_key_here

# OAuth/session token
# ANTHROPIC_AUTH_TOKEN=your_auth_token_here

# Custom API base URL (e.g., proxy or gateway)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Cloud provider (set to 1 + configure provider credentials)
# CLAUDE_CODE_USE_BEDROCK=1     # Amazon Bedrock (requires AWS credentials)
# CLAUDE_CODE_USE_VERTEX=1      # Google Vertex AI (requires GCP credentials)
# CLAUDE_CODE_USE_FOUNDRY=1     # Microsoft Azure Foundry (requires Azure credentials)

# Dynamic key retrieval via shell command
# CLAUDE_API_KEY_HELPER=bash -c 'cat /path/to/secret'

# Optional: Model override (defaults to Claude Code's default) 
# sonnet, opus, haiku
# MODEL=claude-sonnet-4-20250514

# Optional: Max QA rounds before stopping (default: 3)
# MAX_QA_ROUNDS=3

# Optional: Max budget in USD (default: 50)
# MAX_BUDGET_USD=50
